{
  "name": "litellm",
  "description": "LiteLLM proxy server for Claude models",
  "env": {},
  "permissions_allow": [
    "mcp__tavily__tavily_search",
    "mcp__tavily__tavily_research",
    "mcp__duckduckgo__search"
  ],
  "permissions_deny": [
    "WebSearch",
    "WebFetch"
  ],
  "required_config": [
    "base_url",
    "auth_token"
  ]
}
