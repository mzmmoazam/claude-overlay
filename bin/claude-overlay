#!/usr/bin/env bash
# claude-overlay — manage project-level Claude Code config for custom providers
#
# Uses an overlay approach: only the provider-specific keys are toggled.
# Other project settings, MCP servers, and permissions are left untouched.
#
# Usage:
#   claude-overlay [setup] [options]   — create provider overlay for this project
#   claude-overlay disable             — remove overlay, keep other settings
#   claude-overlay enable              — restore overlay alongside other settings
#   claude-overlay status              — show current state
#   claude-overlay configure           — create/update user config file
#   claude-overlay self-update         — update to latest release
#   claude-overlay --version           — print version
#   claude-overlay --help              — print help

set -euo pipefail

VERSION="0.2.0"

# ── Resolve paths (macOS-compatible, no readlink -f) ───────────────────────
resolve_dir() {
  local target="$1"
  if [ -L "$target" ]; then
    target="$(cd "$(dirname "$target")" && readlink "$(basename "$target")")"
  fi
  (cd "$(dirname "$target")" && pwd -P)
}

SCRIPT_DIR="$(resolve_dir "${BASH_SOURCE[0]}")"
LIB_DIR="$(cd "$SCRIPT_DIR/../lib/claude-overlay" 2>/dev/null && pwd -P)" || LIB_DIR="$(cd "$SCRIPT_DIR/../lib" 2>/dev/null && pwd -P)" || LIB_DIR=""

# ── Colours ────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $*"; }
info() { echo -e "${BLUE}→${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }
dim()  { echo -e "${DIM}$*${NC}"; }
dbg()  { [ "${CLAUDE_OVERLAY_DEBUG:-}" = "1" ] && echo -e "${DIM}[debug] $*${NC}" >&2 || true; }

# ── Paths ──────────────────────────────────────────────────────────────────
SETTINGS_FILE=".claude/settings.local.json"
MCP_FILE=".mcp.json"
OVERLAY_FILE=".claude/provider-overlay.json"
XDG_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}"
CONFIG_FILE="$XDG_CONFIG/claude-overlay/config.json"

# Legacy paths
LEGACY_SETTINGS_OFF=".claude/settings.local.json.disabled"
LEGACY_MCP_OFF=".mcp.json.disabled"
LEGACY_OVERLAY=".claude/databricks-overlay.json"

# ── Preflight ──────────────────────────────────────────────────────────────
preflight() {
  if ! command -v python3 >/dev/null 2>&1; then
    err "python3 is required but not found. Install Python 3.7+ to use claude-overlay."
    exit 1
  fi
  if ! python3 -c "import sys; sys.exit(0 if sys.version_info >= (3,7) else 1)" 2>/dev/null; then
    err "python3 >= 3.7 is required. Found: $(python3 --version 2>&1)"
    exit 1
  fi
  if [ -z "$LIB_DIR" ] || [ ! -f "$LIB_DIR/engine.py" ]; then
    err "Cannot find lib/engine.py. Expected at: $LIB_DIR/engine.py"
    err "Re-install claude-overlay or check your installation."
    exit 1
  fi
  dbg "LIB_DIR=$LIB_DIR"
  dbg "CONFIG_FILE=$CONFIG_FILE"
}

# ── Engine wrapper ─────────────────────────────────────────────────────────
py_engine() {
  dbg "py_engine $1"
  python3 "$LIB_DIR/engine.py" "$@"
}

# ── Require config file ───────────────────────────────────────────────────
require_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    err "No config found at $CONFIG_FILE"
    echo ""
    info "Run 'claude-overlay configure' to set up your provider credentials."
    echo ""
    exit 1
  fi
}

# ── Migrate legacy files if present ───────────────────────────────────────
migrate_legacy_if_needed() {
  local needs_migration=false
  [ -f "$LEGACY_SETTINGS_OFF" ] && needs_migration=true
  [ -f "$LEGACY_MCP_OFF" ] && needs_migration=true
  [ -f "$LEGACY_OVERLAY" ] && [ ! -f "$OVERLAY_FILE" ] && needs_migration=true

  if [ "$needs_migration" = true ]; then
    warn "Detected legacy files — migrating to new format…"
    result=$(py_engine migrate_legacy) || true
    if [ "$result" = "migrated" ]; then
      ok "Legacy files migrated and cleaned up"
    fi
  fi
}

# ── Update .gitignore ─────────────────────────────────────────────────────
update_gitignore() {
  touch .gitignore
  local entries=(
    ".claude/settings.local.json"
    ".mcp.json"
    ".claude/provider-overlay.json"
    ".claude/databricks-overlay.json"
    ".claude/settings.local.json.disabled"
    ".mcp.json.disabled"
  )
  for entry in "${entries[@]}"; do
    if ! grep -qF "$entry" .gitignore; then
      echo "$entry" >> .gitignore
      ok "Added $entry to .gitignore"
    else
      dbg "$entry already in .gitignore"
    fi
  done
}

# ══════════════════════════════════════════════════════════════════════════
# Configure: shared helpers and per-provider functions
# ══════════════════════════════════════════════════════════════════════════

# Module-level state set by per-provider functions, consumed by write_config
_cfg_base_url=""
_cfg_auth_token_value=""
_cfg_auth_token_source=""
_cfg_custom_headers=""
_cfg_model=""
_cfg_opus=""
_cfg_sonnet=""
_cfg_haiku=""
_cfg_tavily_key=""
_cfg_mcp_skip=false
_cfg_mcp_duckduckgo_only=false

# ── Shared: prompt for auth token ─────────────────────────────────────────
prompt_auth_token() {
  local env_var_name="$1"
  local detected_value="$2"

  echo ""
  echo -e "  ${BLUE}How to provide your auth token:${NC}"
  echo "    1) env:$env_var_name — reads from environment variable (recommended)"
  echo "    2) Raw token value — stored directly in config (less secure)"
  echo ""

  if [ -n "$detected_value" ]; then
    echo -e "  ${GREEN}✓${NC} Detected \$$env_var_name in environment"
    echo -ne "${YELLOW}?${NC} Use env:$env_var_name? ${DIM}(Y/n)${NC} "
    read -r use_env
    if [[ "$use_env" =~ ^[Nn] ]]; then
      echo -ne "${YELLOW}?${NC} Auth token value: "
      read -r _cfg_auth_token_value
      _cfg_auth_token_source="raw"
    else
      _cfg_auth_token_value="env:$env_var_name"
      _cfg_auth_token_source="env"
    fi
  else
    echo -ne "${YELLOW}?${NC} Auth token or env: reference: "
    read -r _cfg_auth_token_value
    if [ -z "$_cfg_auth_token_value" ]; then err "Auth token is required."; exit 1; fi
    if [[ "$_cfg_auth_token_value" == env:* ]]; then
      _cfg_auth_token_source="env"
    else
      _cfg_auth_token_source="raw"
      warn "Storing raw token. Consider using env:$env_var_name instead."
    fi
  fi
}

# ── Shared: MCP server selection ──────────────────────────────────────────
configure_mcp_servers() {
  echo ""
  echo -e "${BOLD}MCP Web Search Servers${NC}"
  echo -e "${DIM}Replace native WebSearch/WebFetch with MCP-based alternatives.${NC}"
  echo ""
  echo "  1) Tavily + DuckDuckGo (recommended, Tavily requires API key)"
  echo "  2) DuckDuckGo only (no API key needed)"
  echo "  3) Skip — I'll configure MCP servers myself"
  echo ""
  echo -ne "${YELLOW}?${NC} Selection ${DIM}[1]${NC}: "
  read -r mcp_choice

  case "${mcp_choice:-1}" in
    1)
      echo -ne "${YELLOW}?${NC} Tavily API key or env: reference ${DIM}(enter for env:TAVILY_API_KEY)${NC}: "
      read -r _cfg_tavily_key
      [ -z "$_cfg_tavily_key" ] && _cfg_tavily_key="env:TAVILY_API_KEY"
      _cfg_mcp_skip=false
      _cfg_mcp_duckduckgo_only=false
      ;;
    2)
      _cfg_mcp_skip=false
      _cfg_mcp_duckduckgo_only=true
      ;;
    3)
      _cfg_mcp_skip=true
      ;;
    *)
      warn "Invalid choice, using default (Tavily + DuckDuckGo)"
      echo -ne "${YELLOW}?${NC} Tavily API key or env: reference ${DIM}(enter for env:TAVILY_API_KEY)${NC}: "
      read -r _cfg_tavily_key
      [ -z "$_cfg_tavily_key" ] && _cfg_tavily_key="env:TAVILY_API_KEY"
      _cfg_mcp_skip=false
      _cfg_mcp_duckduckgo_only=false
      ;;
  esac
}

# ── Shared: write config file ─────────────────────────────────────────────
write_config() {
  local provider_key="$1"

  mkdir -p "$(dirname "$CONFIG_FILE")"

  export _CFG_PROVIDER="$provider_key"
  export _CFG_BASE_URL="$_cfg_base_url"
  export _CFG_AUTH_TOKEN="$_cfg_auth_token_value"
  export _CFG_MODEL="$_cfg_model"
  export _CFG_OPUS="$_cfg_opus"
  export _CFG_SONNET="$_cfg_sonnet"
  export _CFG_HAIKU="$_cfg_haiku"
  export _CFG_HEADERS="${_cfg_custom_headers:-}"
  export _CFG_TAVILY_KEY="${_cfg_tavily_key:-}"
  export _CFG_MCP_SKIP="${_cfg_mcp_skip:-false}"
  export _CFG_MCP_DDG_ONLY="${_cfg_mcp_duckduckgo_only:-false}"
  export _CFG_PATH="$CONFIG_FILE"

  python3 -c "
import json, os

provider_key = os.environ['_CFG_PROVIDER']
provider_conf = {
    'base_url': os.environ['_CFG_BASE_URL'],
    'auth_token': os.environ['_CFG_AUTH_TOKEN'],
    'model': os.environ['_CFG_MODEL'],
    'opus_model': os.environ['_CFG_OPUS'],
    'sonnet_model': os.environ['_CFG_SONNET'],
    'haiku_model': os.environ['_CFG_HAIKU'],
}
headers = os.environ.get('_CFG_HEADERS', '')
if headers:
    provider_conf['custom_headers'] = headers

# Load existing config and merge (preserves other providers)
path = os.environ['_CFG_PATH']
config = {}
if os.path.isfile(path):
    try:
        with open(path) as f:
            config = json.load(f)
    except (json.JSONDecodeError, OSError):
        config = {}

config.setdefault('version', 1)
config['default_provider'] = provider_key
config.setdefault('providers', {})[provider_key] = provider_conf

mcp_servers = config.get('mcp_servers', {})
mcp_skip = os.environ.get('_CFG_MCP_SKIP', 'false') == 'true'
ddg_only = os.environ.get('_CFG_MCP_DDG_ONLY', 'false') == 'true'

if not mcp_skip:
    if not ddg_only:
        tavily_key = os.environ.get('_CFG_TAVILY_KEY', 'env:TAVILY_API_KEY')
        mcp_servers['tavily'] = {
            'type': 'stdio',
            'command': 'npx',
            'args': ['-y', 'tavily-mcp@0.3.1'],
            'env': {'TAVILY_API_KEY': tavily_key}
        }
    mcp_servers['duckduckgo'] = {
        'type': 'stdio',
        'command': 'npx',
        'args': ['-y', 'duckduckgo-mcp-server@1.1.0']
    }

config['mcp_servers'] = mcp_servers

os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, 'w') as f:
    json.dump(config, f, indent=2)
    f.write('\n')
os.chmod(path, 0o600)
"

  echo ""
  ok "Config saved to $CONFIG_FILE (chmod 600)"
  echo ""

  if [ "$_cfg_auth_token_source" = "env" ]; then
    local env_var_name="${_cfg_auth_token_value#env:}"
    info "Remember to set your env vars in ~/.zshrc or ~/.bashrc:"
    echo ""
    echo "  export $env_var_name=\"your-token\""
    if [[ "${_cfg_tavily_key:-}" == env:* ]]; then
      local tavily_var="${_cfg_tavily_key#env:}"
      echo "  export $tavily_var=\"your-tavily-key\""
    fi
    echo ""
  fi

  dim "Next: cd into a project and run 'claude-overlay setup'"
  echo ""
}

# ── Per-provider: Databricks ──────────────────────────────────────────────
configure_databricks() {
  local detected_host="${DATABRICKS_HOST:-}"
  local detected_token="${DATABRICKS_TOKEN:-}"

  # Try ~/.databrickscfg if env var not set
  if [ -z "$detected_host" ] && [ -f "$HOME/.databrickscfg" ]; then
    detected_host=$(python3 -c "
import configparser, os
c = configparser.ConfigParser()
c.read(os.path.expanduser('~/.databrickscfg'))
print(c.get('DEFAULT', 'host', fallback=''))
" 2>/dev/null)
  fi

  # Build URL from host if detected
  local default_url=""
  if [ -n "$detected_host" ]; then
    default_url="${detected_host%/}/serving-endpoints/anthropic"
    [[ "$default_url" != https://* ]] && default_url="https://$default_url"
    echo -e "  ${GREEN}✓${NC} Detected DATABRICKS_HOST: $detected_host"
  fi

  if [ -n "$default_url" ]; then
    echo -ne "${YELLOW}?${NC} Databricks base URL ${DIM}[$default_url]${NC}: "
    read -r _cfg_base_url
    [ -z "$_cfg_base_url" ] && _cfg_base_url="$default_url"
  else
    echo -ne "${YELLOW}?${NC} Databricks base URL (https://...): "
    read -r _cfg_base_url
  fi

  if [[ ! "$_cfg_base_url" =~ ^https:// ]]; then
    err "Base URL must start with https:// — got: $_cfg_base_url"
    exit 1
  fi

  prompt_auth_token "DATABRICKS_TOKEN" "$detected_token"

  _cfg_custom_headers="x-databricks-use-coding-agent-mode: true"
  _cfg_model="databricks-claude-opus-4-6"
  _cfg_opus="databricks-claude-opus-4-6"
  _cfg_sonnet="databricks-claude-sonnet-4-6"
  _cfg_haiku="databricks-claude-haiku-4-5"
}

# ── Per-provider: OpenRouter ──────────────────────────────────────────────
configure_openrouter() {
  _cfg_base_url="https://openrouter.ai/api"
  info "Using fixed endpoint: $_cfg_base_url"

  local detected_key="${OPENROUTER_API_KEY:-}"
  prompt_auth_token "OPENROUTER_API_KEY" "$detected_key"

  _cfg_custom_headers=""
  _cfg_model="anthropic/claude-opus-4.6"
  _cfg_opus="anthropic/claude-opus-4.6"
  _cfg_sonnet="anthropic/claude-sonnet-4.6"
  _cfg_haiku="anthropic/claude-haiku-4.5"
}

# ── Per-provider: LiteLLM ────────────────────────────────────────────────
configure_litellm() {
  local detected_key="${LITELLM_MASTER_KEY:-}"

  echo -ne "${YELLOW}?${NC} LiteLLM proxy URL ${DIM}[http://localhost:4000]${NC}: "
  read -r _cfg_base_url
  [ -z "$_cfg_base_url" ] && _cfg_base_url="http://localhost:4000"

  if [[ ! "$_cfg_base_url" =~ ^https?:// ]]; then
    err "Base URL must start with http:// or https:// — got: $_cfg_base_url"
    exit 1
  fi

  prompt_auth_token "LITELLM_MASTER_KEY" "$detected_key"

  echo ""
  info "LiteLLM model names depend on your proxy config."
  echo -ne "${YELLOW}?${NC} Default model name ${DIM}[claude-sonnet-4-6]${NC}: "
  read -r _cfg_model
  [ -z "$_cfg_model" ] && _cfg_model="claude-sonnet-4-6"

  echo -ne "${YELLOW}?${NC} Opus model ${DIM}[claude-opus-4-6]${NC}: "
  read -r _cfg_opus
  [ -z "$_cfg_opus" ] && _cfg_opus="claude-opus-4-6"

  echo -ne "${YELLOW}?${NC} Sonnet model ${DIM}[$_cfg_model]${NC}: "
  read -r _cfg_sonnet
  [ -z "$_cfg_sonnet" ] && _cfg_sonnet="$_cfg_model"

  echo -ne "${YELLOW}?${NC} Haiku model ${DIM}[claude-haiku-4-5]${NC}: "
  read -r _cfg_haiku
  [ -z "$_cfg_haiku" ] && _cfg_haiku="claude-haiku-4-5"

  _cfg_custom_headers=""
}

# ── Per-provider: Cloudflare AI Gateway ──────────────────────────────────
configure_cloudflare() {
  local detected_account="${CF_ACCOUNT_ID:-}"
  local detected_gateway="${CF_GATEWAY_ID:-}"
  local detected_key="${ANTHROPIC_API_KEY:-}"

  echo -e "${DIM}Cloudflare AI Gateway is a transparent proxy to Anthropic.${NC}"
  echo -e "${DIM}Native WebSearch/WebFetch will work. MCP search is optional.${NC}"
  echo ""

  # Account ID
  local account_id gateway_id cf_gw_token
  if [ -n "$detected_account" ]; then
    echo -e "  ${GREEN}✓${NC} Detected CF_ACCOUNT_ID"
    echo -ne "${YELLOW}?${NC} Cloudflare Account ID ${DIM}[$detected_account]${NC}: "
  else
    echo -ne "${YELLOW}?${NC} Cloudflare Account ID: "
  fi
  read -r account_id
  [ -z "$account_id" ] && account_id="$detected_account"
  [ -z "$account_id" ] && { err "Account ID is required."; exit 1; }

  # Gateway ID
  if [ -n "$detected_gateway" ]; then
    echo -e "  ${GREEN}✓${NC} Detected CF_GATEWAY_ID"
    echo -ne "${YELLOW}?${NC} Gateway ID ${DIM}[$detected_gateway]${NC}: "
  else
    echo -ne "${YELLOW}?${NC} Gateway ID: "
  fi
  read -r gateway_id
  [ -z "$gateway_id" ] && gateway_id="$detected_gateway"
  [ -z "$gateway_id" ] && { err "Gateway ID is required."; exit 1; }

  _cfg_base_url="https://gateway.ai.cloudflare.com/v1/${account_id}/${gateway_id}/anthropic"
  info "Constructed URL: $_cfg_base_url"

  echo ""
  echo -e "${DIM}The auth token is your Anthropic API key (Cloudflare forwards it).${NC}"
  prompt_auth_token "ANTHROPIC_API_KEY" "$detected_key"

  # Optional CF gateway auth header
  echo ""
  echo -ne "${YELLOW}?${NC} CF gateway auth token ${DIM}(enter to skip — only needed if gateway requires auth)${NC}: "
  read -r cf_gw_token
  if [ -n "$cf_gw_token" ]; then
    _cfg_custom_headers="cf-aig-authorization: Bearer $cf_gw_token"
  else
    _cfg_custom_headers=""
  fi

  _cfg_model="claude-sonnet-4-6"
  _cfg_opus="claude-opus-4-6"
  _cfg_sonnet="claude-sonnet-4-6"
  _cfg_haiku="claude-haiku-4-5"
}

# ── Per-provider: Amazon Bedrock (gateway) ────────────────────────────────
configure_bedrock() {
  echo -e "${DIM}For standard Bedrock, use CLAUDE_CODE_USE_BEDROCK=1 instead.${NC}"
  echo -e "${DIM}This is for Bedrock accessed through a custom API gateway.${NC}"
  echo ""

  echo -ne "${YELLOW}?${NC} Bedrock gateway URL (https://...): "
  read -r _cfg_base_url

  if [[ ! "$_cfg_base_url" =~ ^https:// ]]; then
    err "Base URL must start with https:// — got: $_cfg_base_url"
    exit 1
  fi

  prompt_auth_token "BEDROCK_GATEWAY_TOKEN" ""

  _cfg_custom_headers=""
  _cfg_model="us.anthropic.claude-opus-4-6-v1"
  _cfg_opus="us.anthropic.claude-opus-4-6-v1"
  _cfg_sonnet="us.anthropic.claude-sonnet-4-6"
  _cfg_haiku="us.anthropic.claude-haiku-4-5-20251001-v1:0"
}

# ── Per-provider: Custom ──────────────────────────────────────────────────
configure_custom() {
  echo -ne "${YELLOW}?${NC} Base URL (https://... or http://...): "
  read -r _cfg_base_url

  if [[ ! "$_cfg_base_url" =~ ^https?:// ]]; then
    err "Base URL must start with http:// or https:// — got: $_cfg_base_url"
    exit 1
  fi

  echo ""
  echo -ne "${YELLOW}?${NC} Auth token or env: reference: "
  read -r _cfg_auth_token_value
  [ -z "$_cfg_auth_token_value" ] && { err "Auth token is required."; exit 1; }
  if [[ "$_cfg_auth_token_value" == env:* ]]; then
    _cfg_auth_token_source="env"
  else
    _cfg_auth_token_source="raw"
    warn "Storing raw token."
  fi

  echo -ne "${YELLOW}?${NC} Default model name: "
  read -r _cfg_model

  echo -ne "${YELLOW}?${NC} Opus model ${DIM}[$_cfg_model]${NC}: "
  read -r _cfg_opus
  [ -z "$_cfg_opus" ] && _cfg_opus="$_cfg_model"

  echo -ne "${YELLOW}?${NC} Sonnet model ${DIM}[$_cfg_model]${NC}: "
  read -r _cfg_sonnet
  [ -z "$_cfg_sonnet" ] && _cfg_sonnet="$_cfg_model"

  echo -ne "${YELLOW}?${NC} Haiku model ${DIM}[$_cfg_model]${NC}: "
  read -r _cfg_haiku
  [ -z "$_cfg_haiku" ] && _cfg_haiku="$_cfg_model"

  echo -ne "${YELLOW}?${NC} Custom headers ${DIM}(enter to skip)${NC}: "
  read -r _cfg_custom_headers
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: configure
# ══════════════════════════════════════════════════════════════════════════
cmd_configure() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Configure${NC}"
  echo -e "${DIM}Setting up provider credentials${NC}"
  echo ""

  # ── Show existing config info ────────────────────────────────────────────
  if [ -f "$CONFIG_FILE" ]; then
    local existing_info
    existing_info=$(python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
providers = sorted(d.get('providers', {}).keys())
default = d.get('default_provider', '')
print(f'{default}|{\",\".join(providers)}')
" "$CONFIG_FILE" 2>/dev/null || echo "unknown|")
    local existing_default="${existing_info%%|*}"
    local existing_list="${existing_info#*|}"
    info "Existing config: default=${BLUE}$existing_default${NC}, providers=[$existing_list]"
    dim "  New provider will be added (existing providers are preserved)."
    echo ""
  fi

  # ── Provider selection ───────────────────────────────────────────────────
  local providers=("Databricks" "OpenRouter" "LiteLLM" "Cloudflare AI Gateway" "Amazon Bedrock (gateway)" "Custom / Generic")
  local provider_keys=("databricks" "openrouter" "litellm" "cloudflare" "bedrock-gateway" "custom")

  echo -e "${BOLD}Select your provider:${NC}"
  echo ""
  local i
  for i in "${!providers[@]}"; do
    echo "  $((i + 1))) ${providers[$i]}"
  done
  echo ""
  echo -ne "${YELLOW}?${NC} Enter number: "
  read -r selection

  # Validate selection
  if ! [[ "$selection" =~ ^[0-9]+$ ]] || [ "$selection" -lt 1 ] || [ "$selection" -gt "${#providers[@]}" ]; then
    err "Invalid selection: $selection"
    exit 1
  fi

  local idx=$((selection - 1))
  local provider_key="${provider_keys[$idx]}"

  echo ""
  info "Configuring: ${providers[$idx]}"
  echo ""

  # ── Dispatch to provider-specific configure ──────────────────────────────
  case "$provider_key" in
    databricks)      configure_databricks ;;
    openrouter)      configure_openrouter ;;
    litellm)         configure_litellm ;;
    cloudflare)      configure_cloudflare ;;
    bedrock-gateway) configure_bedrock ;;
    custom)          configure_custom ;;
  esac

  # ── MCP server selection ─────────────────────────────────────────────────
  configure_mcp_servers

  # ── Write config ─────────────────────────────────────────────────────────
  write_config "$provider_key"
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: switch
# ══════════════════════════════════════════════════════════════════════════
cmd_switch() {
  local target="${1:-}"

  echo ""
  echo -e "${BOLD}Claude Overlay — Switch Provider${NC}"
  echo ""

  require_config

  if [ -z "$target" ]; then
    # Interactive mode: list providers and prompt
    local list_json
    list_json=$(py_engine switch_provider)
    local current
    current=$(python3 -c "import json,sys; print(json.loads(sys.argv[1])['default'])" "$list_json")
    local providers_str
    providers_str=$(python3 -c "import json,sys; print('\n'.join(json.loads(sys.argv[1])['providers']))" "$list_json")

    if [ -z "$providers_str" ]; then
      err "No providers configured. Run 'claude-overlay configure' first."
      exit 1
    fi

    local i=1
    while IFS= read -r p; do
      if [ "$p" = "$current" ]; then
        echo -e "  ${i}) ${GREEN}${BOLD}$p${NC} ${DIM}(current)${NC}"
      else
        echo "  ${i}) $p"
      fi
      i=$((i + 1))
    done <<< "$providers_str"
    echo ""

    echo -ne "${YELLOW}?${NC} Switch to: "
    read -r selection

    # Map number to name
    target=$(python3 -c "
import json, sys
providers = json.loads(sys.argv[1])['providers']
try:
    idx = int(sys.argv[2]) - 1
    if 0 <= idx < len(providers):
        print(providers[idx])
    else:
        print('')
except ValueError:
    # Might be a name directly
    print(sys.argv[2] if sys.argv[2] in providers else '')
" "$list_json" "$selection")

    if [ -z "$target" ]; then
      err "Invalid selection."
      exit 1
    fi
  fi

  export _SWITCH_TO="$target"
  local result
  result=$(py_engine switch_provider) || true

  case "$result" in
    ok)
      ok "Switched default provider to ${BOLD}$target${NC}"
      echo ""
      dim "Run 'claude-overlay setup' in your project to apply the new provider."
      echo "" ;;
    already_default)
      info "$target is already the default provider."
      echo "" ;;
    error:unknown_provider:*)
      err "Provider '$target' not found in config."
      echo ""
      info "Available providers:"
      unset _SWITCH_TO
      py_engine switch_provider | python3 -c "import json,sys; [print(f'  • {p}') for p in json.loads(sys.stdin.read())['providers']]"
      echo ""
      exit 1 ;;
    *)
      err "Switch failed: $result"
      exit 1 ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: export
# ══════════════════════════════════════════════════════════════════════════
cmd_export() {
  require_config
  py_engine export_config
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: import
# ══════════════════════════════════════════════════════════════════════════
cmd_import() {
  local import_file="${1:-}"

  if [ -z "$import_file" ]; then
    err "Usage: claude-overlay import <config-file>"
    exit 1
  fi

  if [ ! -f "$import_file" ]; then
    err "File not found: $import_file"
    exit 1
  fi

  echo ""
  echo -e "${BOLD}Claude Overlay — Import Config${NC}"
  echo ""

  # Show what's being imported
  local preview
  preview=$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    providers = sorted(d.get('providers', {}).keys())
    default = d.get('default_provider', '')
    mcp = sorted(d.get('mcp_servers', {}).keys())
    print(f'Provider(s): {\", \".join(providers) or \"none\"}')
    print(f'Default: {default or \"none\"}')
    if mcp:
        print(f'MCP servers: {\", \".join(mcp)}')
except Exception as e:
    print(f'Error: {e}')
    sys.exit(1)
" "$import_file" 2>&1) || {
    err "Invalid config file."
    exit 1
  }

  echo "$preview"
  echo ""

  export _IMPORT_PATH="$import_file"
  local result
  result=$(py_engine import_config) || true

  case "$result" in
    ok)
      ok "Config imported and merged into $CONFIG_FILE"
      echo ""
      dim "Run 'claude-overlay setup' in your project to apply."
      echo "" ;;
    error:*)
      err "Import failed: $result"
      exit 1 ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: status
# ══════════════════════════════════════════════════════════════════════════
cmd_status() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Project Status${NC}"
  echo -e "${DIM}$PWD${NC}"
  echo ""

  migrate_legacy_if_needed

  if [ ! -f "$OVERLAY_FILE" ]; then
    echo -e "  Provider       ${DIM}not set up${NC}"
    echo ""

    if [ -f "$SETTINGS_FILE" ] || [ -f "$MCP_FILE" ]; then
      info "Existing project config detected (not managed by this tool):"
      [ -f "$SETTINGS_FILE" ] && echo "    $SETTINGS_FILE"
      [ -f "$MCP_FILE" ]      && echo "    $MCP_FILE"
      echo ""
    fi

    dim "  Run 'claude-overlay setup' to set up provider + MCP web search."
    echo ""
    return
  fi

  status_json=$(py_engine status)

  python3 - "$status_json" <<'PYEOF'
import json, sys

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

s = json.loads(sys.argv[1])

if s["overlay_enabled"]:
    print(f"  Provider       {GREEN}{BOLD}ENABLED{NC}")
    print(f"  Model          {BLUE}{s['model']}{NC}")
    print(f"  Endpoint       {DIM}{s['base_url']}{NC}")
elif s["has_overlay"]:
    if s["overlay_partial"]:
        print(f"  Provider       {YELLOW}{BOLD}PARTIAL{NC}  {DIM}(overlay partially applied — run enable to fix){NC}")
    else:
        print(f"  Provider       {YELLOW}{BOLD}DISABLED{NC}  {DIM}(overlay saved, ready to enable){NC}")
else:
    print(f"  Provider       {DIM}not set up{NC}")

print()

if s["managed_mcp_active"]:
    print(f"  {GREEN}Managed MCP servers:{NC}")
    for name in s["managed_mcp_active"]:
        print(f"    {GREEN}●{NC} {name}")
elif s["managed_mcp"]:
    print(f"  {DIM}Managed MCP servers (disabled):{NC}")
    for name in s["managed_mcp"]:
        print(f"    {DIM}○ {name}{NC}")

if s["other_mcp"]:
    print(f"  {BLUE}Other MCP servers (untouched):{NC}")
    for name in s["other_mcp"]:
        print(f"    {BLUE}●{NC} {name}")

print()

if s["managed_deny"]:
    print(f"  Native tools   {RED}denied: {', '.join(s['managed_deny'])}{NC}")
if s["managed_allow"]:
    print(f"  MCP tools      {GREEN}pre-approved: {', '.join(s['managed_allow'])}{NC}")
if s["other_allow"]:
    # Truncate long entries for display
    items = [x[:60] + '...' if len(x) > 60 else x for x in s["other_allow"]]
    print(f"  Other allow    {BLUE}{len(s['other_allow'])} rule(s){NC}")
if s["other_deny"]:
    print(f"  Other deny     {BLUE}{', '.join(s['other_deny'])}{NC}")

if s["other_env_keys"]:
    print()
    print(f"  {BLUE}Other env vars (untouched):{NC}")
    for k in s["other_env_keys"]:
        print(f"    {BLUE}•{NC} {k}")
PYEOF

  echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: disable
# ══════════════════════════════════════════════════════════════════════════
cmd_disable() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Disabling provider overlay${NC}"
  echo -e "${DIM}$PWD${NC}"
  echo ""

  migrate_legacy_if_needed

  if [ ! -f "$OVERLAY_FILE" ]; then
    err "No overlay found. Run 'claude-overlay setup' first."
    echo ""
    exit 1
  fi

  status_json=$(py_engine status)
  is_enabled=$(python3 -c "import json,sys; s=json.loads(sys.argv[1]); print('yes' if s['overlay_enabled'] else 'no')" "$status_json")

  if [ "$is_enabled" = "no" ]; then
    warn "Overlay is already disabled."
    echo ""
    exit 0
  fi

  info "Removing overlay keys from project config…"
  info "Other settings and MCP servers will be preserved."
  echo ""

  output=$(py_engine remove)

  while IFS= read -r line; do
    case $line in
      settings:trimmed)  ok ".claude/settings.local.json — overlay keys removed, other settings kept" ;;
      settings:removed)  ok ".claude/settings.local.json — empty after removal, file cleaned up" ;;
      mcp:trimmed)       ok ".mcp.json — overlay MCP servers removed, other servers kept" ;;
      mcp:removed)       ok ".mcp.json — no servers left, file cleaned up" ;;
      error:*)           err "$line" ;;
    esac
  done <<< "$output"

  echo ""
  echo -e "${YELLOW}${BOLD}Overlay disabled.${NC}"
  dim "Claude Code will now use global settings + native web search."
  dim "Other project settings and MCP servers are untouched."
  dim "Run 'claude-overlay enable' to restore."
  echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: enable
# ══════════════════════════════════════════════════════════════════════════
cmd_enable() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Enabling provider overlay${NC}"
  echo -e "${DIM}$PWD${NC}"
  echo ""

  migrate_legacy_if_needed

  if [ ! -f "$OVERLAY_FILE" ]; then
    err "No overlay found. Run 'claude-overlay setup' first."
    echo ""
    exit 1
  fi

  status_json=$(py_engine status)
  is_enabled=$(python3 -c "import json,sys; s=json.loads(sys.argv[1]); print('yes' if s['overlay_enabled'] else 'no')" "$status_json")

  if [ "$is_enabled" = "yes" ]; then
    warn "Overlay is already enabled."
    echo ""
    exit 0
  fi

  info "Merging overlay keys into project config…"
  info "Existing settings and MCP servers will be preserved."
  echo ""

  result=$(py_engine merge) || true

  if [ "$result" = "ok" ]; then
    ok ".claude/settings.local.json — provider env vars + permissions merged"
    ok ".mcp.json — MCP web search servers merged"
  else
    err "Failed: $result"
    exit 1
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Overlay enabled.${NC}"
  dim "Other project settings and MCP servers are untouched."
  dim "Verify inside Claude Code with: /mcp"
  echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: setup
# ══════════════════════════════════════════════════════════════════════════
cmd_setup() {
  local AUTO_YES=false
  local DRY_RUN=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      -y|--yes) AUTO_YES=true; shift ;;
      --dry-run) DRY_RUN=true; shift ;;
      -h|--help)
        show_help
        exit 0 ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done

  echo ""
  echo -e "${BOLD}Claude Overlay — Project Setup${NC}"
  echo -e "${DIM}Provider overlay + MCP web search${NC}"
  echo ""

  migrate_legacy_if_needed
  require_config

  # ── Load config via engine ──────────────────────────────────────────────
  info "Loading config from $CONFIG_FILE"
  export _PRESET_DIR="$LIB_DIR/presets"
  local config_json
  config_json=$(py_engine load_config) || true

  # Check for errors
  case "$config_json" in
    error:env_var_not_set:*)
      local var_name="${config_json#error:env_var_not_set:}"
      err "Environment variable $var_name is not set."
      echo ""
      info "Add to your shell profile:"
      echo "  export $var_name=\"your-value\""
      echo ""
      exit 1 ;;
    error:*)
      err "Config error: $config_json"
      exit 1 ;;
  esac

  # ── Extract values from resolved config ─────────────────────────────────
  local provider base_url auth_token model opus sonnet haiku headers
  provider=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['provider'])" "$config_json")
  base_url=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['base_url'])" "$config_json")
  auth_token=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['auth_token'])" "$config_json")
  model=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['model'])" "$config_json")
  opus=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['opus_model'])" "$config_json")
  sonnet=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['sonnet_model'])" "$config_json")
  haiku=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['haiku_model'])" "$config_json")
  headers=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(c['resolved']['custom_headers'])" "$config_json")

  # Extract MCP servers and permissions as JSON strings
  local mcp_servers_json permissions_allow_json permissions_deny_json
  mcp_servers_json=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(json.dumps(c['mcp_servers']))" "$config_json")
  permissions_allow_json=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(json.dumps(c['permissions_allow']))" "$config_json")
  permissions_deny_json=$(python3 -c "import json,sys; c=json.loads(sys.argv[1]); print(json.dumps(c['permissions_deny']))" "$config_json")

  # ── Preview ─────────────────────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}Project directory:${NC} $PWD"
  echo ""
  echo -e "${BOLD}What this will do:${NC}"
  echo "  1. Save provider overlay to .claude/provider-overlay.json"
  echo "  2. Merge env vars + permissions into .claude/settings.local.json"
  echo "  3. Merge MCP web search servers into .mcp.json"
  echo "  4. Update .gitignore"
  echo ""
  if [ -f "$SETTINGS_FILE" ] || [ -f "$MCP_FILE" ]; then
    echo -e "  ${BLUE}Existing settings and MCP servers will be preserved.${NC}"
    echo ""
  fi
  echo -e "${BOLD}Provider: ${BLUE}$provider${NC}"
  echo "  Base URL   : $base_url"
  echo "  Model      : $model"
  echo "  Auth token : ${auth_token:0:12}…"

  # Show MCP servers that will be added
  local mcp_count
  mcp_count=$(python3 -c "import json,sys; print(len(json.loads(sys.argv[1])))" "$mcp_servers_json")
  if [ "$mcp_count" -gt 0 ]; then
    echo ""
    echo -e "${BOLD}MCP servers:${NC}"
    python3 -c "
import json, sys
servers = json.loads(sys.argv[1])
for name, conf in servers.items():
    cmd = ' '.join(conf.get('args', []))
    print(f'  + {name} ({conf.get(\"command\",\"\")} {cmd})')
" "$mcp_servers_json"
  fi
  echo ""

  if [ "$DRY_RUN" = true ]; then
    dim "[dry-run] No files were modified."
    echo ""
    exit 0
  fi

  # ── Confirmation ────────────────────────────────────────────────────────
  if [ "$AUTO_YES" = false ]; then
    echo -ne "Proceed? ${DIM}(Y/n)${NC} "
    read -r confirm
    if [[ "$confirm" =~ ^[Nn] ]]; then echo "Aborted."; exit 0; fi
  fi
  echo ""

  # ── Create overlay ──────────────────────────────────────────────────────
  mkdir -p .claude
  export _OV_MODEL="$model" _OV_BASE_URL="$base_url" _OV_AUTH_TOKEN="$auth_token"
  export _OV_OPUS="$opus" _OV_SONNET="$sonnet" _OV_HAIKU="$haiku"
  export _OV_HEADERS="$headers"
  export _OV_MCP_SERVERS="$mcp_servers_json"
  export _OV_PERMISSIONS_ALLOW="$permissions_allow_json"
  export _OV_PERMISSIONS_DENY="$permissions_deny_json"

  result=$(py_engine create_overlay) || true
  if [ "$result" = "ok" ]; then
    ok "Saved overlay → .claude/provider-overlay.json"
  else
    err "Failed to create overlay: $result"; exit 1
  fi

  # ── Merge ───────────────────────────────────────────────────────────────
  result=$(py_engine merge) || true
  if [ "$result" = "ok" ]; then
    ok "Merged config → .claude/settings.local.json"
    ok "Merged MCP servers → .mcp.json"
  else
    err "Failed to merge: $result"; exit 1
  fi

  # ── Gitignore ───────────────────────────────────────────────────────────
  update_gitignore

  # ── Done ────────────────────────────────────────────────────────────────
  echo ""
  echo -e "${GREEN}${BOLD}All done!${NC} Project is ready."
  echo ""
  dim "  claude-overlay status   — see what's active vs. managed"
  dim "  claude-overlay disable  — remove overlay, keep other settings"
  dim "  claude-overlay enable   — restore overlay alongside other settings"
  dim "  /mcp                    — verify inside Claude Code"
  echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: doctor
# ══════════════════════════════════════════════════════════════════════════
cmd_doctor() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Health Check${NC}"
  echo ""

  local has_error=false

  # ── Check 1: python3 ──
  if command -v python3 >/dev/null 2>&1; then
    local py_ver
    py_ver=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')")
    local py_minor
    py_minor=$(python3 -c "import sys; print(sys.version_info.minor)")
    if [ "$py_minor" -ge 7 ] 2>/dev/null; then
      echo -e "  ${GREEN}✓${NC} python3 $py_ver"
    else
      echo -e "  ${RED}✗${NC} python3 $py_ver (need >= 3.7)"
      has_error=true
    fi
  else
    echo -e "  ${RED}✗${NC} python3 not found"
    has_error=true
  fi

  # ── Check 2: npx ──
  if command -v npx >/dev/null 2>&1; then
    echo -e "  ${GREEN}✓${NC} npx available"
  else
    echo -e "  ${RED}✗${NC} npx not found (needed for MCP servers)"
    has_error=true
  fi

  # ── Checks 3–8: config validation (delegated to Python) ──
  local diag_json
  diag_json=$(python3 - "$CONFIG_FILE" <<'PYEOF'
import json, os, sys

config_path = sys.argv[1]
results = []

# Check 3: config exists
if not os.path.isfile(config_path):
    results.append({"id": 3, "level": "error", "msg": f"No config — run 'claude-overlay configure'", "detail": config_path})
    print(json.dumps(results))
    sys.exit(0)

results.append({"id": 3, "level": "ok", "msg": f"Config: {config_path}"})

# Check 4: valid JSON
try:
    with open(config_path) as f:
        config = json.load(f)
except (json.JSONDecodeError, OSError) as e:
    results.append({"id": 4, "level": "error", "msg": f"Config is malformed JSON: {e}"})
    print(json.dumps(results))
    sys.exit(0)

results.append({"id": 4, "level": "ok", "msg": "Config valid JSON"})

# Check 5: default provider
provider_name = config.get("default_provider", "")
if not provider_name:
    results.append({"id": 5, "level": "error", "msg": "No default_provider in config"})
    print(json.dumps(results))
    sys.exit(0)

providers = config.get("providers", {})
provider = providers.get(provider_name, {})
if not provider:
    results.append({"id": 5, "level": "error", "msg": f"Provider '{provider_name}' not found in providers"})
    print(json.dumps(results))
    sys.exit(0)

results.append({"id": 5, "level": "ok", "msg": f"Provider: {provider_name}"})

# Check 6: base_url
base_url = provider.get("base_url", "")
if not base_url:
    results.append({"id": 6, "level": "error", "msg": f"Missing base_url for {provider_name}"})
else:
    # Truncate for display
    display_url = base_url if len(base_url) <= 60 else base_url[:57] + "..."
    results.append({"id": 6, "level": "ok", "msg": f"Endpoint: {display_url}"})

# Check 7: auth token
auth_token = provider.get("auth_token", "")
if not auth_token:
    results.append({"id": 7, "level": "error", "msg": f"Missing auth_token for {provider_name}"})
elif auth_token.startswith("env:"):
    env_var = auth_token[4:]
    if os.environ.get(env_var, ""):
        results.append({"id": 7, "level": "ok", "msg": f"Auth: {auth_token} → set"})
    else:
        results.append({"id": 7, "level": "error", "msg": f"Auth: {auth_token} → NOT SET in environment"})
else:
    results.append({"id": 7, "level": "ok", "msg": "Auth: token configured (inline)"})

# Check 8: Tavily key
mcp_servers = config.get("mcp_servers", {})
tavily = mcp_servers.get("tavily", {})
if tavily:
    tavily_env = tavily.get("env", {})
    tavily_key_ref = tavily_env.get("TAVILY_API_KEY", "")
    if tavily_key_ref.startswith("env:"):
        env_var = tavily_key_ref[4:]
        if os.environ.get(env_var, ""):
            results.append({"id": 8, "level": "ok", "msg": f"Tavily: {tavily_key_ref} → set"})
        else:
            results.append({"id": 8, "level": "warn", "msg": f"Tavily: {tavily_key_ref} → NOT SET (Tavily search won't work)"})
    elif tavily_key_ref:
        results.append({"id": 8, "level": "ok", "msg": "Tavily: key configured"})
    else:
        results.append({"id": 8, "level": "warn", "msg": "Tavily: no API key configured"})

print(json.dumps(results))
PYEOF
  ) || true

  # Parse and display Python diagnostics
  if [ -n "$diag_json" ]; then
    python3 -c "
import json, sys
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
icons = {'ok': f'{GREEN}✓{NC}', 'error': f'{RED}✗{NC}', 'warn': f'{YELLOW}⚠{NC}', 'info': f'{BLUE}ℹ{NC}'}
for r in json.loads(sys.argv[1]):
    print(f'  {icons[r[\"level\"]]} {r[\"msg\"]}')
" "$diag_json"
    # Check if any errors in diagnostics
    if python3 -c "import json,sys; sys.exit(0 if any(r['level']=='error' for r in json.loads(sys.argv[1])) else 1)" "$diag_json" 2>/dev/null; then
      has_error=true
    fi
  fi

  # ── Check 9: project overlay ──
  echo ""
  if [ -f "$OVERLAY_FILE" ]; then
    echo -e "  ${GREEN}✓${NC} Overlay: $OVERLAY_FILE"

    # ── Check 10: overlay enabled ──
    if [ -f "$SETTINGS_FILE" ]; then
      local is_enabled
      is_enabled=$(python3 -c "
import json, sys
ov = json.load(open(sys.argv[1]))
s = json.load(open(sys.argv[2]))
ov_env = ov.get('env', {})
s_env = s.get('env', {})
# Check if any overlay key is present in settings
print('yes' if ov_env and any(k in s_env for k in ov_env) else 'no')
" "$OVERLAY_FILE" "$SETTINGS_FILE" 2>/dev/null) || true
      if [ "$is_enabled" = "yes" ]; then
        echo -e "  ${GREEN}✓${NC} Status: ENABLED"
      else
        echo -e "  ${YELLOW}⚠${NC} Status: DISABLED — run 'claude-overlay enable'"
      fi
    else
      echo -e "  ${YELLOW}⚠${NC} Status: DISABLED — run 'claude-overlay enable'"
    fi
  else
    echo -e "  ${BLUE}ℹ${NC} No overlay in this directory"
    dim "    Run 'claude-overlay setup' to set up this project."
  fi

  echo ""

  if [ "$has_error" = true ]; then
    exit 1
  fi
}

# ══════════════════════════════════════════════════════════════════════════
# Subcommand: self-update
# ══════════════════════════════════════════════════════════════════════════
cmd_self_update() {
  echo ""
  echo -e "${BOLD}Claude Overlay — Self Update${NC}"
  echo ""

  if ! command -v curl >/dev/null 2>&1; then
    err "curl is required for self-update."
    exit 1
  fi

  local repo="mzmmoazam/claude-overlay"
  local api_url="https://api.github.com/repos/$repo/releases/latest"

  info "Checking for latest release…"
  local release_json
  release_json=$(curl -fsSL "$api_url" 2>/dev/null) || {
    err "Failed to fetch release info from GitHub."
    exit 1
  }

  local latest_version
  latest_version=$(python3 -c "import json,sys; print(json.loads(sys.stdin.read())['tag_name'].lstrip('v'))" <<< "$release_json")

  if [ "$latest_version" = "$VERSION" ]; then
    ok "Already on the latest version ($VERSION)."
    echo ""
    exit 0
  fi

  info "Updating: v$VERSION → v$latest_version"

  local tarball_url
  tarball_url=$(python3 -c "import json,sys; print(json.loads(sys.stdin.read())['tarball_url'])" <<< "$release_json")

  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' EXIT

  curl -fsSL "$tarball_url" -o "$tmpdir/release.tar.gz" || {
    err "Failed to download release."
    exit 1
  }

  tar -xzf "$tmpdir/release.tar.gz" -C "$tmpdir" --strip-components=1

  # Determine install prefix from current location
  local install_bin
  install_bin="$(resolve_dir "${BASH_SOURCE[0]}")"
  local install_prefix
  install_prefix="$(cd "$install_bin/.." && pwd -P)"

  # Atomic replace — copy new files to temp, then mv
  cp "$tmpdir/bin/claude-overlay" "$tmpdir/claude-overlay.new"
  chmod 755 "$tmpdir/claude-overlay.new"
  mv "$tmpdir/claude-overlay.new" "$install_prefix/bin/claude-overlay"

  # Update lib
  mkdir -p "$install_prefix/lib/claude-overlay/presets"
  cp "$tmpdir/lib/engine.py" "$install_prefix/lib/claude-overlay/engine.py"
  cp "$tmpdir/lib/presets/"*.json "$install_prefix/lib/claude-overlay/presets/" 2>/dev/null || true

  ok "Updated to v$latest_version"
  echo ""
}

# ══════════════════════════════════════════════════════════════════════════
# Help
# ══════════════════════════════════════════════════════════════════════════
show_help() {
  cat <<EOF

${BOLD}claude-overlay${NC} v$VERSION — manage project-level Claude Code config for custom providers

${BOLD}Usage:${NC}
  claude-overlay [command] [options]

${BOLD}Commands:${NC}
  setup        Set up provider overlay for this project (default)
  disable      Remove overlay keys, keep other settings
  enable       Restore overlay keys alongside other settings
  status       Show current state of project config
  configure    Create or update user config file
  switch       Switch active provider (multi-provider configs)
  export       Export config for team sharing
  import       Import a shared config file
  doctor       Check setup health (config, env vars, project)
  self-update  Update to the latest release

${BOLD}Setup options:${NC}
  -y, --yes    Skip confirmation prompts
  --dry-run    Show what would happen without making changes

${BOLD}Global options:${NC}
  --version    Print version
  --help       Show this help
  --debug      Enable verbose debug output

${BOLD}First time?${NC}
  1. claude-overlay configure    # set up your credentials
  2. cd your-project
  3. claude-overlay setup        # enable overlay in project

${BOLD}Config file:${NC} ${DIM}$CONFIG_FILE${NC}

EOF
}

# ══════════════════════════════════════════════════════════════════════════
# Router
# ══════════════════════════════════════════════════════════════════════════
SUBCOMMAND="${1:-setup}"

# Handle --flags before subcommands
case "$SUBCOMMAND" in
  --version)
    echo "claude-overlay $VERSION"
    exit 0 ;;
  --help|-h)
    preflight
    show_help
    exit 0 ;;
  --debug)
    export CLAUDE_OVERLAY_DEBUG=1
    shift
    SUBCOMMAND="${1:-setup}"
    ;;
esac

# Shift subcommand off if it's a named command (not a flag)
if [[ "$SUBCOMMAND" != --* ]]; then
  shift 2>/dev/null || true
else
  SUBCOMMAND="setup"
fi

preflight

case $SUBCOMMAND in
  setup)       cmd_setup "$@" ;;
  enable)      cmd_enable ;;
  disable)     cmd_disable ;;
  status)      cmd_status ;;
  configure)   cmd_configure ;;
  switch)      cmd_switch "$@" ;;
  export)      cmd_export ;;
  import)      cmd_import "$@" ;;
  doctor)      cmd_doctor ;;
  self-update) cmd_self_update ;;
  *)
    err "Unknown command: $SUBCOMMAND"
    echo ""
    echo "Run 'claude-overlay --help' for usage."
    echo ""
    exit 1 ;;
esac
